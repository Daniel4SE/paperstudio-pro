{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode": {
      "options": {}
    },
    "google": {
      "models": {
        // ─── Gemini 2.5 Image (override family to separate from text models) ───
        "gemini-2.5-flash-image": {
          "family": "gemini-flash-image",
          "release_date": "2025-08-26"
        },
        "gemini-2.5-flash-image-preview": {
          "family": "gemini-flash-image-preview",
          "release_date": "2025-08-26"
        },
        // ─── Gemini Native Image Gen (Nano-Banana series) ───
        "gemini-3.1-flash-image-preview": {
          "name": "Gemini 3.1 Flash Image (Nano-Banana 2)",
          "family": "gemini-nano-banana",
          "release_date": "2026-01-15",
          "tool_call": true,
          "reasoning": true,
          "temperature": true,
          "attachment": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text", "image"]
          },
          "limit": { "context": 1048576, "output": 8192 }
        },
        "gemini-3-pro-image-preview": {
          "name": "Gemini 3 Pro Image (Nano-Banana Pro)",
          "family": "gemini-nano-banana-pro",
          "release_date": "2025-12-01",
          "tool_call": true,
          "reasoning": true,
          "temperature": true,
          "attachment": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text", "image"]
          },
          "limit": { "context": 1048576, "output": 8192 }
        },
        // ─── Imagen 4 (Dedicated Image Gen) ───
        "imagen-4.0-generate-001": {
          "name": "Imagen 4.0",
          "family": "imagen-4",
          "release_date": "2025-12-01",
          "tool_call": false,
          "reasoning": false,
          "temperature": false,
          "attachment": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["image"]
